program SyntaxExample

abstract class Shape 
{
    int x, y;
    {
        abstract int area();
        void move(int dx, int dy)
        {
            x = x + dx;
            y = y + dy;
        }
    }
}

class Square extends Shape
{
    int side;
    {
        int area()
        {
            return side * side;
        }
    }
}

{
    void main() 
        Square s;
        int i;
    {
        s = new Square;
        s.side = 5;
        s.move(10, 10);
        
        print(s.area());
        print(eol);
    }
}